# Demo pipeline configuration
# Copy this file to .env and adjust as needed:  cp .env.example .env

# Target date for prediction (requires 7 days of prior data in CSV)
TARGET_DATE=2026-01-15

# Gap injection mode: "blocks" or "random"
GAP_MODE=blocks

# Block gap parameters (used when GAP_MODE=blocks)
BLOCK_LENGTH=36
N_BLOCKS=2

# Random gap parameters (used when GAP_MODE=random)
N_POINTS=50

# Random seed for reproducibility
SEED=42

# --- Path overrides (optional, only if data lives elsewhere) ---
# DEMO_DATA_DIR=/app/phase-2/Data
# DEMO_MODEL_DIR=/app/phase-2/Prediction Model/docker-previsions-conso/build/previsions_conso/code
# DEMO_OUTPUT_DIR=/app/demo/output
